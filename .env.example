# BloodConnect Backend - Environment Variables Configuration
# Copy this file to .env and fill in actual values for deployment
# SECURITY WARNING: Never commit .env file with real secrets to version control

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
# MySQL database connection URL
# Format: jdbc:mysql://host:port/database_name
# Example: jdbc:mysql://db.example.com:3306/bloodconnect_prod
DATABASE_URL=jdbc:mysql://localhost:3306/bloodconnect_db

# MySQL database username
DATABASE_USERNAME=root

# MySQL database password (REQUIRED - NO DEFAULT)
# Use a strong password with alphanumeric characters, symbols, and numbers
# Minimum 12 characters recommended
DATABASE_PASSWORD=your_secure_database_password_here

# ============================================
# SERVER CONFIGURATION (OPTIONAL)
# ============================================
# Server port (default: 9292)
PORT=9292

# File upload directory (for community hub images, documents, etc.)
# Use full paths with forward slashes
# Windows: C:/path/to/uploads or /c/path/to/uploads
# Linux/Mac: /var/app/uploads
UPLOAD_DIR=/app/uploads

# ============================================
# JWT AUTHENTICATION (REQUIRED)
# ============================================
# JWT secret key for token signing and verification (REQUIRED - NO DEFAULT)
# Use a cryptographically secure random string
# Generate with: openssl rand -base64 32
# Minimum 32 characters (256-bit) recommended
JWT_SECRET=your_secure_jwt_secret_key_here_minimum_32_characters

# ============================================
# SPRING SECURITY (REQUIRED)
# ============================================
# Default Spring Security username (used if no proper authentication exists)
SPRING_SECURITY_USER_NAME=admin

# Default Spring Security password (REQUIRED - NO DEFAULT)
# Use a strong password
SPRING_SECURITY_USER_PASSWORD=your_secure_admin_password_here

# ============================================
# EMAIL CONFIGURATION (REQUIRED for notifications)
# ============================================
# Email sender username (Gmail: your-email@gmail.com)
# Note: For Gmail, enable "Less secure app access" or use App Password
MAIL_USERNAME=your-email@gmail.com

# Email sender password or App Password (REQUIRED - NO DEFAULT)
# For Gmail: Generate an App Password at https://myaccount.google.com/apppasswords
# Do NOT use your Gmail account password directly
MAIL_PASSWORD=your_gmail_app_password_here

# ============================================
# OPENROUTER AI CONFIGURATION (REQUIRED for AI features)
# ============================================
# OpenRouter API Key (REQUIRED - NO DEFAULT)
# Get from: https://openrouter.ai/keys
# Format: sk-or-v1-xxxxxxxxxxxxxx...
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# OpenRouter API URL (optional, has default)
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# OpenRouter model to use (optional, has default)
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ============================================
# CLOUDINARY CONFIGURATION (REQUIRED for image hosting)
# ============================================
# Cloudinary Cloud Name (optional, has default for development)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Cloudinary API Key (REQUIRED - NO DEFAULT)
# Get from: https://cloudinary.com/console/settings/api-keys
CLOUDINARY_API_KEY=your_cloudinary_api_key_here

# Cloudinary API Secret (REQUIRED - NO DEFAULT)
# Get from: https://cloudinary.com/console/settings/api-keys
# IMPORTANT: Keep this secret, never expose in logs or version control
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ============================================
# OAUTH SOCIAL LOGIN CONFIGURATION (REQUIRED if using social login)
# ============================================
# Google OAuth 2.0 Client ID
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Apple OAuth Configuration
# Create at: https://developer.apple.com/account/resources/identifiers/list
APPLE_TEAM_ID=your_apple_team_id_here

# Apple Key ID
APPLE_KEY_ID=your_apple_key_id_here

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Set strong password for DATABASE_PASSWORD (min 12 chars, mixed alphanumeric + symbols)
# [ ] Set strong JWT_SECRET (use: openssl rand -base64 32)
# [ ] Set strong SPRING_SECURITY_USER_PASSWORD
# [ ] Configure MAIL_USERNAME and MAIL_PASSWORD with valid credentials
# [ ] Provide valid OPENROUTER_API_KEY from https://openrouter.ai
# [ ] Configure Cloudinary credentials (CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET)
# [ ] Set OAuth credentials if social login is enabled
# [ ] Verify DATABASE_URL points to production database
# [ ] Set UPLOAD_DIR to production path with write permissions
# [ ] Never commit .env file to version control
# [ ] Use a secrets management system (HashiCorp Vault, AWS Secrets Manager, etc.)

# ============================================
# SECURITY BEST PRACTICES
# ============================================
# 1. Never commit the .env file to Git
#    Add to .gitignore: .env
#
# 2. Use different secrets for each environment (dev, staging, prod)
#
# 3. Rotate secrets regularly:
#    - JWT_SECRET every 30 days
#    - MAIL_PASSWORD every 60 days
#    - API keys after team member departures
#
# 4. Use a secrets manager in production:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Google Secret Manager
#
# 5. Monitor for exposed secrets:
#    - Use git hooks to prevent secret commits
#    - Scan repositories with tools like TruffleHog
#
# 6. Audit access to secrets:
#    - Log who accesses what secrets
#    - Alert on suspicious access patterns

# Spring Security
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=secure_password

# JWT
JWT_SECRET=BloodConnectSuperSecretKeyForJWTAuthentication2026BloodConnect

# Email Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# File Upload
UPLOAD_DIR=/tmp/uploads

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
